Content/Mannequin/
Content/Mannequin/**

# Starter Content
Content/StarterContent/
Content/StarterContent/**

# Default Template Content
Content/ThirdPerson/
Content/ThirdPerson/**

Content/FirstPerson/
Content/FirstPerson/**

Content/TopDown/
Content/TopDown/**

Content/Vehicle/
Content/Vehicle/**

# Optional Default Template Folders
Content/Variant_Horror/
Content/Variant_Horror/**

Content/Variant_Shooter/
Content/Variant_Shooter/**

Content/Variant_Combat/
Content/Variant_Combat/**
